// Pixel shader do batcher de LINHAS: devolve a cor do vertice, e so. O alpha
// alimenta o blend SRC_ALPHA/ONE_MINUS_SRC_ALPHA do pipeline.

STRUCT(VSOutput)
{
    DATA(float4, Position, SV_Position);
    DATA(float4, Color, COLOR);
};

ROOT_SIGNATURE(DefaultRootSignature)
float4 PS_MAIN(VSOutput In)
{
    INIT_MAIN;
    RETURN(In.Color);
}
